rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperuser() {
      return request.auth != null
             && request.auth.token.email == 'admin@os.com';
    }

    // os-site_content: public read, superuser write.
    match /os-site_content/{document} {
      allow read: if true;
      allow write: if isSuperuser();
    }

    // os-feedback: public create, superuser moderation.
    match /os-feedback/{document} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'message', 'status', 'timestamp'])
                    && request.resource.data.name is string
                    && request.resource.data.message is string
                    && request.resource.data.status == 'pending'
                    && request.resource.data.timestamp == request.time;
      allow read: if isSuperuser()
                  || resource.data.status == 'approved';
      allow update, delete: if isSuperuser();
    }
  }
}
