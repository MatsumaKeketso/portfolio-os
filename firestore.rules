rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // os-site_content — public read, authenticated write (admin only)
    match /os-site_content/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // os-feedback — public write (submissions), authenticated read (admin moderation)
    match /os-feedback/{document} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'message', 'status', 'timestamp'])
                    && request.resource.data.name is string
                    && request.resource.data.message is string
                    && request.resource.data.status == 'pending';
      allow read, update, delete: if request.auth != null;
    }
  }
}
