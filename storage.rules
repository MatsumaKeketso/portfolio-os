rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Admin-uploaded assets (backgrounds, milestone images)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Visitor Gallery — image-only, size-limited, no auth required
    match /visitor-gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }
  }
}
